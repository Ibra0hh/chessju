# Copy this file to .env.production on the server and replace every placeholder.
# Do not commit .env.production.

APP_ENV=production
CHESSJU_APP_NAME=ChessJU API
CHESSJU_APP_VERSION=0.1.0
CHESSJU_ENVIRONMENT=production
CHESSJU_DEBUG=false
CHESSJU_API_V1_PREFIX=/api/v1

# Caddy listens on these host ports. Keep 80/443 for a normal public server.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# Use a real domain in production, for example chessju.example.com.
# For local config validation without HTTPS, use http://localhost.
CADDY_SITE_ADDRESS=chessju.example.com
CADDY_ACME_EMAIL=admin@example.com

# API is only exposed internally to Caddy in docker-compose.prod.yml.
# Keep this only for compatibility with older scripts; production compose does not publish it.
API_HOST_PORT=8001

POSTGRES_DB=chessju
POSTGRES_USER=chessju
POSTGRES_PASSWORD=replace-with-a-strong-random-password
CHESSJU_DATABASE_URL=postgresql+psycopg://chessju:replace-with-a-strong-random-password@postgres:5432/chessju

CHESSJU_VALKEY_URL=redis://valkey:6379/0
CHESSJU_LOCAL_STORAGE_ROOT=/data/storage

CHESSJU_JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
CHESSJU_JWT_ALGORITHM=HS256
CHESSJU_ACCESS_TOKEN_EXPIRE_MINUTES=15
CHESSJU_REFRESH_TOKEN_EXPIRE_DAYS=30

CHESSJU_STOCKFISH_PATH=/usr/games/stockfish
CHESSJU_STOCKFISH_DEPTH_DEFAULT=10
CHESSJU_STOCKFISH_DEPTH_MAX=16
CHESSJU_ANALYSIS_MAX_PLIES=300
CHESSJU_ANALYSIS_JOB_TIMEOUT_SECONDS=120

CHESSJU_CHESSCOM_SYNC_MAX_MONTHS=3
CHESSJU_CHESSCOM_SYNC_TIMEOUT_SECONDS=120
CHESSJU_CHESSCOM_USER_AGENT=ChessJU/0.1 contact: admin@example.com

# Lock this to the production Flutter web/admin origins.
# Do not use wildcard origins with credentials enabled.
CHESSJU_CORS_ALLOWED_ORIGINS=https://chessju.example.com
CHESSJU_CORS_ALLOW_CREDENTIALS=true
CHESSJU_CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CHESSJU_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID

CHESSJU_RATE_LIMIT_ENABLED=true
CHESSJU_RATE_LIMIT_LOGIN_PER_MINUTE=10
CHESSJU_RATE_LIMIT_REGISTER_PER_HOUR=10
CHESSJU_RATE_LIMIT_PGN_PER_HOUR=20
CHESSJU_RATE_LIMIT_ANALYSIS_PER_HOUR=10
CHESSJU_RATE_LIMIT_CHESSCOM_SYNC_PER_HOUR=5
CHESSJU_RATE_LIMIT_MESSAGE_PER_MINUTE=60
